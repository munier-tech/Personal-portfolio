# Example environment variables
# Copy this file to .env.local and fill in your actual values

# Email configuration (optional)
# NEXT_PUBLIC_EMAIL_FROM=your-email@gmail.com
# NEXT_PUBLIC_EMAIL_TO=contact@yourname.com

# Social Links (update with your actual links)
# NEXT_PUBLIC_GITHUB_URL=https://github.com/yourname
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourname
# NEXT_PUBLIC_TWITTER_URL=https://twitter.com/yourname
